---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageCTA from '../components/PageCTA.astro';
import '../styles/global.css';
import mainScriptUrl from '../scripts/main.js?url';

interface Props {
  title: string;
  description: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, structuredData = [] } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const canonical = new URL(Astro.url.pathname, Astro.site);
const siteUrl = new URL(base, Astro.site ?? Astro.url.origin).toString();
const logoUrl = new URL(base + 'assets/images/branding/logo.webp', Astro.site ?? Astro.url.origin).toString();
const socialImage = new URL(base + 'assets/images/index_img_slider-2.webp', Astro.site ?? Astro.url.origin).toString();
const currentPage = Astro.url.pathname.split('/').pop() || 'index.html';
const formspreeEndpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || undefined;
const pageName = title.split('|')[0].trim();

const organizationSchema = {
  '@type': ['ProfessionalService', 'Organization'],
  '@id': siteUrl + '#organization',
  name: 'PileTeST Consultants (PVT) LTD',
  alternateName: 'PileTeST',
  url: siteUrl,
  logo: logoUrl,
  image: socialImage,
  description,
  foundingDate: '2014',
  telephone: '+94703600600',
  email: 'info@piletest.lk',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '655A Halgahadeniya Road',
    addressLocality: 'Gothatuwa',
    addressCountry: 'LK'
  },
  areaServed: { '@type': 'Country', name: 'Sri Lanka' },
  sameAs: [
    'https://www.facebook.com/www.piletest.lk',
    'https://www.linkedin.com/company/pile-test-consultants-pvt-ltd/posts/?feedView=all'
  ],
  knowsAbout: [
    'Dynamic pile testing',
    'Pile integrity testing',
    'Cross-hole sonic logging',
    'Static load testing',
    'Geotechnical investigation',
    'Construction vibration monitoring'
  ]
};
const websiteSchema = {
  '@type': 'WebSite',
  '@id': siteUrl + '#website',
  url: siteUrl,
  name: 'PileTeST Consultants',
  publisher: { '@id': siteUrl + '#organization' },
  inLanguage: 'en'
};
const breadcrumbSchema = currentPage === 'index.html' ? null : {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL(base + 'index.html', Astro.site ?? Astro.url.origin).toString() },
    { '@type': 'ListItem', position: 2, name: pageName, item: canonical.toString() }
  ]
};
const extraSchemas = Array.isArray(structuredData) ? structuredData : [structuredData];
const graph = [organizationSchema, websiteSchema, ...(breadcrumbSchema ? [breadcrumbSchema] : []), ...extraSchemas];
const schemaJson = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph }).replace(/</g, '\u003c');
---
<!doctype html>
<html lang="en" data-formspree-endpoint={formspreeEndpoint}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F172A" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; frame-src 'self' https://www.google.com; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; upgrade-insecure-requests" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="PileTeST Consultants" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href={`${base}assets/images/branding/favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}assets/images/branding/favicon.png`} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Ubuntu:wght@300;400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
    <script type="application/ld+json" is:inline set:html={schemaJson}></script>
    <title>{title}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      document.documentElement.dataset.theme = savedTheme === 'dark' ? 'dark' : 'light';
    </script>
  </head>
  <body>
    <a class="skip-link" href="#content-start">Skip to main content</a>
    <Header />
    <main><slot /></main>
    {currentPage !== 'contact.html' && <PageCTA />}
    <Footer />
    <script is:inline src={mainScriptUrl}></script>
  </body>
</html>
