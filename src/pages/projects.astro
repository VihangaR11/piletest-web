---
import BaseLayout from '../layouts/BaseLayout.astro';
import content from '../content/pages/projects.html?raw';

const projectSchema = {
  '@type': 'CollectionPage',
  name: 'PileTeST project portfolio and archives',
  description: 'Selected building, infrastructure, industrial, energy and marine foundation-testing projects with searchable project archives.'
};
---
<BaseLayout title="Foundation Testing Projects | PileTeST Consultants" description="Explore landmark, high-rise, infrastructure, industrial, energy, ports and marine foundation-testing projects delivered by PileTeST Consultants." structuredData={projectSchema}>
  <Fragment set:html={content} />
</BaseLayout>
