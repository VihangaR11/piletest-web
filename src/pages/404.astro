---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<BaseLayout title="Page Not Found | PileTeST Consultants" description="The requested PileTeST Consultants page could not be found.">
  <section class="section-dark not-found" id="content-start" tabindex="-1">
    <div class="container">
      <div class="eyebrow-brand-red">Error 404</div>
      <h1>That page is below the surface.</h1>
      <p>The address may have changed, or the page may no longer be available.</p>
      <div class="hero-btns"><a class="btn-primary" href={`${base}index.html`}>Return Home</a><a class="btn-outline" href={`${base}contact.html`}>Contact Us</a></div>
    </div>
  </section>
</BaseLayout>
