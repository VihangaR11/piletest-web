---
import BaseLayout from '../layouts/BaseLayout.astro';
import content from '../content/pages/technical.html?raw';

const technicalTopics = [
  'Technical Articles', 'Case Studies', 'Testing Standards',
  'Design Guidelines', 'Downloads', 'Brochures', 'Method Statements',
  'Publications', 'Frequently Asked Questions'
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'PileTeST technical resources',
  itemListElement: technicalTopics.map((name, index) => ({
    '@type': 'ListItem', position: index + 1, name
  }))
};
---
<BaseLayout title="Technical Resources | PileTeST Consultants" description="Explore PileTeST technical articles, case studies, testing standards, design guidance, downloads, method statements, publications and FAQs." structuredData={structuredData}>
  <Fragment set:html={content} />
</BaseLayout>
