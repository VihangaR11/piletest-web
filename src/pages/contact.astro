---
import BaseLayout from '../layouts/BaseLayout.astro';
import content from '../content/pages/contact.html?raw';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<BaseLayout title="Contact Us | PileTeST Consultants" description="Contact PileTeST Consultants for foundation-testing quotations, technical enquiries, urgent coordination, office locations and company information.">
  <script is:inline src={`${base}contact.js`}></script>
  <Fragment set:html={content} />
</BaseLayout>
