---
import BaseLayout from '../layouts/BaseLayout.astro';
import content from '../content/pages/services.html?raw';
const serviceSchema = {
  '@type': 'ItemList',
  name: 'PileTeST foundation testing and geotechnical services',
  itemListElement: ['Pile Testing Services', 'Geotechnical Investigation', 'Non-Destructive Testing', 'Monitoring and Instrumentation', 'Laboratory Testing', 'Geotechnical Consultancy and Specialized Testing'].map((name, index) => ({ '@type': 'ListItem', position: index + 1, name }))
};
---
<BaseLayout title="Pile Testing & Geotechnical Services | PileTeST Consultants" description="Pile testing, geotechnical investigation, non-destructive testing, monitoring, laboratory testing and foundation engineering consultancy in Sri Lanka." structuredData={serviceSchema}>
  <Fragment set:html={content} />
</BaseLayout>
