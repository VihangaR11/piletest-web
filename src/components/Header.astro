---
import { navigation, site } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname.split('/').pop() || 'index.html';
const pageOf = (href: string) => href.split('#')[0];
const isActive = (item: (typeof navigation)[number]) =>
  pageOf(item.href) === currentPath || item.children?.some((child) =>
    pageOf(child.href) === currentPath || child.children?.some((grandchild) => pageOf(grandchild.href) === currentPath)
  );
---
<header class="site-header">
  <div class="utility-bar">
    <div class="utility-inner">
      <div class="utility-contact">
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={site.phoneHref}>{site.phone}</a>
      </div>
      <div class="utility-trust">
        <span>ISO 9001:2015 Certified</span>
        <a class="utility-profile" href={`${base}brochure.html`}>Company Profile</a>
        <a href={site.linkedin} target="_blank" rel="noopener noreferrer" aria-label="PileTeST on LinkedIn">in</a>
        <a href={site.facebook} target="_blank" rel="noopener noreferrer" aria-label="PileTeST on Facebook">f</a>
      </div>
    </div>
  </div>
  <nav id="navbar" aria-label="Primary navigation">
    <div class="nav-inner">
      <a href={`${base}index.html`} class="nav-logo" aria-label="PileTeST Consultants home">
        <img class="site-logo" src={`${base}assets/images/branding/logo.webp`} alt="PileTeST" width="306" height="82" />
        <div class="logo-text">Consultants (PVT) LTD<br /><span>Testing today. Building tomorrow.</span></div>
      </a>
      <div class="nav-links" id="primary-navigation">
        {navigation.map((item) => item.children ? (
          <div class:list={['dropdown', item.children.some((child) => child.children?.length) && 'dropdown-mega']}>
            <a href={`${base}${item.href}`} aria-current={isActive(item) ? 'page' : undefined} data-mobile-submenu-trigger>
              <span>{item.label}</span>
              <span class="nav-caret" aria-hidden="true"></span>
            </a>
            <button class="nav-dropdown-toggle" type="button" aria-label={`Toggle ${item.label} submenu`} aria-expanded="false">
              <span class="nav-caret" aria-hidden="true"></span>
            </button>
            <div class="dropdown-content">
              {item.children.map((child) => child.children ? (
                <div class="nav-mega-group">
                  <a class="nav-mega-heading" href={`${base}${child.href}`}>{child.label}</a>
                  <div>{child.children.map((grandchild) => <a href={`${base}${grandchild.href}`}>{grandchild.label}</a>)}</div>
                </div>
              ) : <a href={`${base}${child.href}`}>{child.label}</a>)}
            </div>
          </div>
        ) : <a href={`${base}${item.href}`} aria-current={currentPath === item.href ? 'page' : undefined}>{item.label}</a>)}
        <a href={`${base}contact.html#request-quotation`} class="mobile-quote-link">Request a Quote</a>
        <a href={`${base}brochure.html`} class="mobile-profile-link">Company Profile</a>
        <a href={`${base}contact.html`} class="mobile-nav-cta">Contact Us</a>
      </div>
      <button id="mobile-menu-btn" class="hamburger" type="button" aria-label="Open navigation" aria-expanded="false" aria-controls="primary-navigation">Menu</button>
      <div class="nav-actions">
        <a href={`${base}contact.html#request-quotation`} class="nav-quote">Request a Quote</a>
        <a href={`${base}contact.html`} class="nav-contact">Contact Us</a>
      </div>
    </div>
    <button class="nav-scrim" id="nav-scrim" type="button" aria-label="Close navigation" tabindex="-1"></button>
  </nav>
</header>
