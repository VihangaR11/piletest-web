---
import { site } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<nav class="contact-dock" aria-label="Quick contact">
  <a href={site.phoneHref}><span>📞</span><strong>Call</strong></a>
  <a href="https://wa.me/94703600600" target="_blank" rel="noopener"><span>💬</span><strong>WhatsApp</strong></a>
  <a href={`mailto:${site.email}`}><span>✉️</span><strong>Email</strong></a>
  <a href={`${base}contact.html`}><span>📝</span><strong>Enquire</strong></a>
</nav>
<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-logo"><img class="site-logo" src={`${base}assets/images/branding/logo.webp`} alt="PileTeST" width="260" height="87" /><div class="logo-text">Consultants (PVT) LTD<br /><span>Quality Assurance of Deep Foundations</span></div></div>
        <p class="footer-desc">Independent foundation testing, geotechnical investigation and construction monitoring in Sri Lanka since 2014.</p>
        <div class="socials" aria-label="PileTeST social media">
          <a href={site.facebook} class="soc" target="_blank" rel="noopener noreferrer" aria-label="Follow PileTeST on Facebook"><img src={`${base}assets/images/social/facebook.webp`} alt="" width="32" height="32" /></a>
          <a href={site.linkedin} class="soc" target="_blank" rel="noopener noreferrer" aria-label="Follow PileTeST on LinkedIn"><img src={`${base}assets/images/social/linkedin.webp`} alt="" width="32" height="32" /></a>
        </div>
      </div>
      <div><div class="footer-title">Services</div><div class="footer-links"><a href={`${base}services.html#pda`}>Dynamic Pile Testing</a><a href={`${base}services.html#pit`}>PIT Testing</a><a href={`${base}services.html#csl`}>CSL Testing</a><a href={`${base}services.html#slt`}>Static Load Testing</a></div></div>
      <div><div class="footer-title">Explore</div><div class="footer-links"><a href={`${base}about.html`}>About</a><a href={`${base}projects.html`}>Projects</a><a href={`${base}photo.html`}>Gallery</a><a href={`${base}research.html`}>Research</a><a href={`${base}contact.html`}>Contact</a></div></div>
      <div><div class="footer-title">Contact</div><div class="footer-contact"><div>📍 {site.address}</div><div>📞 <a href={site.phoneHref}>{site.phone}</a></div><div>✉️ <a href={`mailto:${site.email}`}>{site.email}</a></div></div></div>
    </div>
    <div class="footer-bottom"><span>© {new Date().getFullYear()} {site.name} · Reg. No. {site.registration}</span><span>Quality Assurance of Deep Foundations</span></div>
  </div>
</footer>
